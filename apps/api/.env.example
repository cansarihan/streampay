# StreamPay API configuration (all optional — sensible testnet defaults are used)

PORT=8787
CORS_ORIGIN=*

# On-chain target. Defaults are read from /deployments/testnet.json when present.
CONTRACT_ID=CCFKV5HTRL33DCWURXES7IX6JR2MWSFW4LSC7UVTWONUPOGANAPETLHT
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NETWORK=testnet

# Local SQLite database file (built-in node:sqlite, no native deps)
DB_PATH=./data/streampay.db

# Indexer
INDEXER_ENABLED=true
INDEXER_INTERVAL_MS=5000
INDEXER_LOOKBACK_LEDGERS=2000
