# StreamPay web configuration (Vite). All optional — testnet defaults are baked in.

# Backend API base URL
VITE_API_URL=http://localhost:8787

# On-chain target (defaults match deployments/testnet.json)
VITE_CONTRACT_ID=CCFKV5HTRL33DCWURXES7IX6JR2MWSFW4LSC7UVTWONUPOGANAPETLHT
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_NETWORK=testnet

# Observability (optional — features are no-ops when unset)
